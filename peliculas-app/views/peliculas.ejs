<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo de Películas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/css/style.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">PeliculasDB</a>
            <div class="d-flex align-items-center">
                <span class="text-light me-3">Bienvenido, <strong><%= name %></strong></span>
                <a href="/logout" class="btn btn-outline-danger btn-sm">Cerrar Sesión</a>
            </div>
        </div>
    </nav>

    <main class="container content-section">
        <div class="table-panel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Catálogo de Películas</h2>
                <% if (role === 'admin') { %>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAdd">
                        + Nueva Película
                    </button>
                <% } %>
            </div>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Año</th>
                        <th>Clasificación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% data.forEach((peli) =>{ %>
                        <tr>
                            <td><%= peli.titulo %></td>
                            <td><%= peli.anio %></td>
                            <td>
                                <span class="badge bg-info text-dark"><%= peli.clasificacion %></span>
                            </td>
                            <td>
                                <% if (role === 'admin') { %>
                                    <a href="/edit/<%= peli.id_pelicula %>" class="btn btn-sm btn-warning">Editar</a>
                                    <a href="/delete/<%= peli.id_pelicula %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar esta película?')">Eliminar</a>
                                <% } else { %>
                                    <span class="badge badge-role bg-secondary">Solo lectura</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <div class="modal fade" id="modalAdd" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form action="/save" method="POST" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Nueva Película</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Título</label>
                <input type="text" name="titulo" class="form-control" placeholder="Ej: Inception" required>
                
                <label class="form-label">Año</label>
                <input type="number" name="anio" max="2025" class="form-control" placeholder="Máximo 2026" required>
                
                <label class="form-label">Sinopsis</label>
                <textarea name="sinopsis" class="form-control" rows="3"></textarea>

                <label class="form-label">Clasificación</label>
                <select name="id_clasificacion" class="form-select" required>
                    <option selected disabled>Selecciona la clasificación</option>
                    
                    <option value="1">PG-13</option>
                    <option value="2">R</option>
                    <option value="3">G</option>
                    <option value="4">B15</option>
                    <option value="5">NC-17</option>
                    <option value="6">PG</option>
                    
                    <option value="7">M</option>
                    <option value="8">U</option>
                    <option value="9">12A</option>
                    <option value="10">16</option>
                    <option value="11">A</option>
                    <option value="12">B</option>
                    <option value="13">C</option>
                    <option value="14">D</option>
                    <option value="15">E</option>
                    
                    <option value="16">PG-10</option>
                    <option value="17">PG-15</option>
                    <option value="18">X</option>
                    <option value="19">Y7</option>
                    <option value="20">TV-MA</option>
                    <option value="21">Infantil</option>
                    <option value="22">Adolescente</option>
                    <option value="23">Adulto</option>
                    <option value="24">Familiar+</option>
                    <option value="25">Cine Arte</option>
                    <option value="26">TV-14</option>
                    <option value="27">TV-PG</option>
                    <option value="28">TV-Y</option>
                    <option value="29">TV-Y7</option>
                    <option value="30">Especial</option>
                </select>
                
                <label class="form-label" style="margin-top: 15px;">País de Origen</label>
                <select name="id_pais" class="form-select">
                    <option selected disabled>Selecciona el país de origen</option>
                    
                    <optgroup label="América">
                        <option value="1">México</option>
                        <option value="2">Estados Unidos</option>
                        <option value="10">Brasil</option>
                        <option value="11">Argentina</option>
                        <option value="13">Canadá</option>
                        <option value="22">Chile</option>
                        <option value="23">Colombia</option>
                        <option value="24">Perú</option>
                    </optgroup>

                    <optgroup label="Europa">
                        <option value="3">Francia</option>
                        <option value="5">Reino Unido</option>
                        <option value="6">Italia</option>
                        <option value="7">Alemania</option>
                        <option value="12">España</option>
                        <option value="16">Rusia</option>
                        <option value="17">Suecia</option>
                        <option value="18">Noruega</option>
                        <option value="25">Países Bajos</option>
                        <option value="26">Bélgica</option>
                        <option value="27">Suiza</option>
                    </optgroup>

                    <optgroup label="Asia">
                        <option value="4">Japón</option>
                        <option value="8">India</option>
                        <option value="14">Corea del Sur</option>
                        <option value="15">China</option>
                        <option value="28">Turquía</option>
                        <option value="29">Irán</option>
                        <option value="30">Tailandia</option>
                    </optgroup>

                    <optgroup label="África">
                        <option value="20">Egipto</option>
                        <option value="21">Sudáfrica</option>
                    </optgroup>

                    <optgroup label="Oceanía">
                        <option value="9">Australia</option>
                        <option value="31">Nueva Zelanda</option>
                    </optgroup>
                </select>
                
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Película</button>
                </div>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>